{
    "name": "baby-wishlist",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --hot server/index.ts",
        "build": "bun run build.ts",
        "start": "NODE_ENV=production bun server/index.ts",
        "seed": "bun server/seed.ts",
        "typecheck": "tsc --noEmit",
        "postinstall": "[ \"$SKIP_APP_POSTINSTALL\" = \"1\" ] && echo 'Skipping app postinstall' || ([ ! -f data/wishlist.db ] && bun run seed || echo 'Database already exists, skipping seed')"
    },
    "dependencies": {
        "@fastify/multipart": "^10.0.0",
        "@tanstack/react-query": "^5.84.1",
        "dotenv": "^17.4.2",
        "fastify": "^5.4.0",
        "lucide-react": "^1.8.0",
        "open-graph-scraper": "^6.10.0",
        "react": "^19",
        "react-dom": "^19",
        "react-router": "^7.14.2",
        "tailwindcss": "^4.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "bun-plugin-tailwind": "^0.1.2",
        "typescript": "5.9.3"
    }
}
